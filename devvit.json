{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "bannerfall",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "index.html",
        "height": "tall"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "reddit": { "enable": true }
  }
}
